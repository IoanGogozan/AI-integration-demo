{
  "name": "ai-integration-demo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @ai-integration/web",
    "dev:api": "npm run dev --workspace @ai-integration/api",
    "dev": "npm run dev:web",
    "start:api": "npm run start --workspace @ai-integration/api",
    "db:generate": "npm run prisma:generate --workspace @ai-integration/api",
    "db:push": "npm run prisma:push --workspace @ai-integration/api",
    "db:seed": "npm run db:seed --workspace @ai-integration/api",
    "db:setup": "npm run db:setup --workspace @ai-integration/api"
  }
}
